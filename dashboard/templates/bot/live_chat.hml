<a href="/bot/config" class="card p-3" style="display:inline-flex;align-items:center;gap:8px;margin-bottom:16px;text-decoration:none">
    {{ icons.i('settings', 16) }} Konfigurasi Bot
</a>
{% endif %}

<h2>Live Chat</h2>
<p>Nanti daftar chat masuk tampil di sini.</p>
{% endblock %}